# ==================== Database Configuration ====================
# Backend: postgresql, sqlite, or firebase
DATABASE_BACKEND=postgresql

# PostgreSQL settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=facebook_scraper

# ==================== Firebase Configuration ====================
# Path to your Firebase service account JSON file
# Download from: Firebase Console > Project Settings > Service Accounts
FIREBASE_CREDENTIALS=path/to/firebase_credentials.json

# ==================== Google Sheets Configuration ====================
# Path to your Google service account JSON file
# Get from: Google Cloud Console > APIs & Services > Credentials
GOOGLE_SHEETS_CREDENTIALS=path/to/google_credentials.json

# ==================== FastAPI Configuration ====================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
CORS_ORIGINS=*

# ==================== ML Configuration ====================
# Directory to store trained models (optional)
ML_MODELS_DIR=
# Number of topics for LDA topic modeling
ML_N_TOPICS=5
# Threshold for sentiment classification
ML_SENTIMENT_THRESHOLD=0.1

# ==================== Facebook Credentials ====================
# Your Facebook login email
FB_EMAIL=your_email@example.com
# Your Facebook password
FB_PASSWORD=your_password
